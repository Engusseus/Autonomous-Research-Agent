{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=autonomous_research_agent_dev;Username=postgres;Password=change-me"
  },
  "Jwt": {
    "Audience": "autonomous-research-agent-api-dev",
    "Issuer": "autonomous-research-agent-dev",
    "SigningKey": "development-only-signing-key-change-before-production",
    "RequireHttpsMetadata": false
  },
  "OpenRouter": {
    "BaseUrl": "https://openrouter.ai/api/v1",
    "Model": "openrouter/hunter-alpha",
    "ApiKey": "",
    "AppTitle": "Autonomous Research Agent",
    "TimeoutSeconds": 120
  },
  "BackgroundJobs": {
    "PollIntervalSeconds": 5
  },
  "DocumentProcessing": {
    "StorageRoot": "data/paper-documents",
    "MaxDownloadSizeMegabytes": 50
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  }
}