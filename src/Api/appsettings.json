{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=autonomous_research_agent;Username=postgres;Password=change-me"
  },
  "Jwt": {
    "Authority": "",
    "Audience": "autonomous-research-agent-api",
    "Issuer": "autonomous-research-agent",
    "SigningKey": "replace-this-development-key-with-a-secure-value",
    "RequireHttpsMetadata": false
  },
  "SemanticScholar": {
    "BaseUrl": "https://api.semanticscholar.org",
    "ApiKey": "",
    "TimeoutSeconds": 30,
    "Fields": "paperId,title,abstract,authors,year,venue,citationCount,externalIds,openAccessPdf"
  },
  "OpenRouter": {
    "BaseUrl": "https://openrouter.ai/api/v1",
    "Model": "openrouter/hunter-alpha",
    "ApiKey": "",
    "AppTitle": "Autonomous Research Agent",
    "TimeoutSeconds": 120
  },
  "BackgroundJobs": {
    "PollIntervalSeconds": 5
  },
  "DocumentProcessing": {
    "StorageRoot": "data/paper-documents",
    "MaxDownloadSizeMegabytes": 50,
    "OcrExecutablePath": "ocrmypdf",
    "OcrFallbackMinimumCharacters": 32
  },
  "LocalEmbedding": {
    "BaseUrl": "http://127.0.0.1:8001",
    "EmbeddingsPath": "embeddings",
    "ModelName": "Snowflake/snowflake-arctic-embed-m-v1.5",
    "TimeoutSeconds": 60,
    "VectorDimensions": 768
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
