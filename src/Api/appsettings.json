{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=autonomous_research_agent;Username=postgres"
  },
  "Jwt": {
    "Authority": "",
    "Audience": "autonomous-research-agent-api",
    "Issuer": "autonomous-research-agent",
    "SigningKey": "",
    "RequireHttpsMetadata": true
  },
  "SemanticScholar": {
    "BaseUrl": "https://api.semanticscholar.org",
    "ApiKey": "",
    "TimeoutSeconds": 30,
    "Fields": "paperId,title,abstract,authors,year,venue,citationCount,externalIds,openAccessPdf"
  },
  "Arxiv": {
    "BaseUrl": "http://export.arxiv.org/api",
    "TimeoutSeconds": 30
  },
  "CrossRef": {
    "BaseUrl": "https://api.crossref.org",
    "UserAgent": "AutonomousResearchAgent/1.0 (mailto:contact@example.com)",
    "TimeoutSeconds": 30
  },
  "OpenRouter": {
    "BaseUrl": "https://openrouter.ai/api/v1",
    "Model": "openrouter/hunter-alpha",
    "Models": ["anthropic/claude-3-haiku", "openai/gpt-4o-mini", "google/gemini-pro"],
    "ApiKey": "",
    "AppTitle": "Autonomous Research Agent",
    "TimeoutSeconds": 120
  },
  "BackgroundJobs": {
    "PollIntervalSeconds": 5
  },
  "DocumentProcessing": {
    "StorageRoot": "/app/data/paper-documents",
    "MaxDownloadSizeMegabytes": 50,
    "OcrExecutablePath": "ocrmypdf",
    "OcrFallbackMinimumCharacters": 32
  },
  "LocalEmbedding": {
    "BaseUrl": "http://127.0.0.1:8001",
    "EmbeddingsPath": "embeddings",
    "ModelName": "Snowflake/snowflake-arctic-embed-m-v1.5",
    "TimeoutSeconds": 60,
    "VectorDimensions": 768
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "",
  "RateLimits": {
    "ExpensivePermitLimit": 10,
    "JobCreationPermitLimit": 20,
    "StandardPermitLimit": 100,
    "WindowSeconds": 60
  }
}
